# Read & Rank — environment variables (Vite, prefix VITE_*)
# Copy to .env.local for local dev. .env.production holds the deployed values.

VITE_API_URL=http://localhost:3000
VITE_ESSENTIALS_URL=http://localhost:5180
VITE_COMPASS_URL=http://localhost:5173
VITE_GOOGLE_MAPS_API_KEY=

# PostHog product analytics.
# Shared Empowered Vote project key (public client-side key — safe to commit).
# Omit VITE_POSTHOG_KEY entirely and analytics is a silent no-op (good for local
# dev when you don't want to pollute production data).
VITE_POSTHOG_KEY=phc_kpUWTjEcRRwSn7zdNstbDVYqAMQvEFZ5EgrWFeaAh5mu
VITE_POSTHOG_HOST=https://us.i.posthog.com
